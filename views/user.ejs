<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Management - Anime Forum</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <div class="flex min-h-screen">

        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow flex flex-col">
            <div class="p-6 text-center border-b">
                <h1 class="text-xl font-bold text-blue-600">Anime Forum Admin</h1>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">
                <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Dashboard</a>
                <a href="/users" class="block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium">Users</a>
            </nav>

            <div class="p-4 text-xs text-gray-500 border-t text-center">
                © 2026 Anime Forum
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-8 overflow-y-auto">
            <div class="mb-6 flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800">User Management</h2>
                    <p class="mt-1 text-sm text-gray-500">Manage forum users and roles</p>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow overflow-hidden">
                <table class="w-full text-sm text-left">
                    <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                        <tr>
                            <th class="px-6 py-3">ID</th>
                            <th class="px-6 py-3">Username</th>
                            <th class="px-6 py-3">Email</th>
                            <th class="px-6 py-3">Role</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y">
                        <% if (!users || users.length===0) { %>
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                                    No users found.
                                </td>
                            </tr>
                            <% } else { %>
                                <% users.forEach((user)=> { %>
                                    <tr class="hover:bg-gray-50">
                                        <td class="px-6 py-4">
                                            <%= user.id %>
                                        </td>
                                        <td class="px-6 py-4 font-medium">
                                            <%= user.username %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <%= user.email %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-1 rounded text-xs bg-gray-100">
                                                <%= user.role %>
                                            </span>
                                        </td>
                                        
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</body>

</html>