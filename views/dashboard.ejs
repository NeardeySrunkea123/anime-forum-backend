<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - Anime Forum</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <div class="flex min-h-screen">

        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow flex flex-col">
            <div class="p-6 text-center border-b">
                <h1 class="text-xl font-bold text-blue-600">Anime Forum Admin</h1>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">
                <a href="/dashboard"
                    class="block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-medium">Dashboard</a>
                <a href="/users" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Users</a>
                <a href="/dashboard/anime" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Anime</a>
            </nav>

            <div class="p-4 text-xs text-gray-500 border-t text-center">
                © 2026 Anime Forum
            </div>
        </aside>

        <!-- Main -->
        <main class="flex-1 p-8 overflow-y-auto">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800">Dashboard Overview</h2>
                    <p class="text-sm text-gray-500 mt-1">Forum analytics, thread activity, and anime data summary</p>
                </div>

                <div class="bg-white border rounded-xl px-4 py-3 shadow-sm text-sm text-gray-500">
                    Generated at:
                    <span id="generatedAt" class="font-semibold text-gray-800">—</span>
                </div>
            </div>

            <!-- Loading + Error -->
            <div id="loading" class="bg-white rounded-2xl shadow p-6 text-gray-600">
                Loading dashboard report...
            </div>

            <div id="errorBox" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-2xl p-4 mb-6"></div>

            <!-- Content -->
            <div id="content" class="hidden space-y-8">

                <!-- Stats cards -->
                <section>
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4">
                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Total Users</div>
                            <div id="totalUsers" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>

                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Total Anime</div>
                            <div id="totalAnime" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>

                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Forums</div>
                            <div id="totalForums" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>

                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Threads</div>
                            <div id="totalThreads" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>

                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Posts</div>
                            <div id="totalPosts" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>

                        <div class="bg-white rounded-2xl shadow-sm p-5 border border-gray-100">
                            <div class="text-xs uppercase tracking-wide text-gray-400">Likes</div>
                            <div id="totalLikes" class="text-3xl font-bold text-gray-800 mt-2">0</div>
                        </div>
                    </div>
                </section>

                <!-- Top threads -->
                <section class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
                    <div class="px-6 py-5 border-b bg-gradient-to-r from-blue-50 to-white">
                        <h3 class="font-semibold text-lg text-gray-800">Top Threads by Engagement</h3>
                        <p class="text-sm text-gray-500 mt-1">Most viewed and most replied discussions</p>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left">
                            <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                                <tr>
                                    <th class="px-6 py-4">Thread</th>
                                    <th class="px-6 py-4">Forum</th>
                                    <th class="px-6 py-4">Anime</th>
                                    <th class="px-6 py-4">Views</th>
                                    <th class="px-6 py-4">Replies</th>
                                    <th class="px-6 py-4">Likes</th>
                                </tr>
                            </thead>
                            <tbody id="engagementBody" class="divide-y"></tbody>
                        </table>
                    </div>
                </section>

                <!-- Forums + anime status -->
                <section class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
                        <div class="px-6 py-5 border-b">
                            <h3 class="font-semibold text-lg text-gray-800">Most Active Forums</h3>
                            <p class="text-sm text-gray-500 mt-1">Forum participation by threads and posts</p>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm text-left">
                                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                                    <tr>
                                        <th class="px-6 py-4">Forum</th>
                                        <th class="px-6 py-4">Threads</th>
                                        <th class="px-6 py-4">Posts</th>
                                    </tr>
                                </thead>
                                <tbody id="activeForumsBody" class="divide-y"></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
                        <div class="px-6 py-5 border-b">
                            <h3 class="font-semibold text-lg text-gray-800">Anime Status Distribution</h3>
                            <p class="text-sm text-gray-500 mt-1">Current anime breakdown by status</p>
                        </div>
                        <div id="animeStatusDistribution" class="p-6 space-y-4"></div>
                    </div>
                </section>

                <!-- Threads report -->
                <section class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
                    <div class="px-6 py-5 border-b">
                        <h3 class="font-semibold text-lg text-gray-800">Threads Report</h3>
                        <p class="text-sm text-gray-500 mt-1">Live data from <span
                                class="font-medium">/api/threads</span></p>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left">
                            <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                                <tr>
                                    <th class="px-6 py-4">Title</th>
                                    <th class="px-6 py-4">Author</th>
                                    <th class="px-6 py-4">Anime</th>
                                    <th class="px-6 py-4">Forum</th>
                                    <th class="px-6 py-4">Views</th>
                                    <th class="px-6 py-4">Posts</th>
                                    <th class="px-6 py-4">Pinned</th>
                                </tr>
                            </thead>
                            <tbody id="threadsReportBody" class="divide-y"></tbody>
                        </table>
                    </div>
                </section>

                <!-- Anime API report -->
                <section class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
                    <div class="px-6 py-5 border-b">
                        <h3 class="font-semibold text-lg text-gray-800">Anime API Report</h3>
                        <p class="text-sm text-gray-500 mt-1">Live anime data from <span
                                class="font-medium">/api/anime</span></p>
                    </div>
                    <div id="animeApiGrid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 p-6"></div>
                </section>

            </div>
        </main>
    </div>

    
    <script>
        function esc(s) {
            return String(s ?? "").replace(/[&<>"']/g, (c) => ({
                "&": "&amp;",
                "<": "&lt;",
                ">": "&gt;",
                '"': "&quot;",
                "'": "&#39;"
            }[c]));
        }

        function normalize(payload) {
            return Array.isArray(payload) ? payload : payload.data || [];
        }

        function badge(status) {
            const s = String(status || "").toLowerCase();
            const cls =
                s === "ongoing" ? "bg-green-50 text-green-700 border-green-200" :
                    s === "completed" ? "bg-blue-50 text-blue-700 border-blue-200" :
                        s === "upcoming" ? "bg-purple-50 text-purple-700 border-purple-200" :
                            "bg-gray-100 text-gray-700 border-gray-200";

            return `<span class="px-2.5 py-1 rounded-full border text-xs font-medium ${cls}">
                    ${esc(status || "Unknown")}
                </span>`;
        }

        function barRow(label, value, total) {
            const pct = total ? Math.round((value / total) * 100) : 0;
            return `
                    <div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="font-medium text-gray-800">${esc(label || "Unknown")}</span>
                            <span class="text-gray-500">${value} (${pct}%)</span>
                        </div>
                        <div class="mt-2 h-2.5 rounded-full bg-gray-100 overflow-hidden">
                            <div class="h-2.5 bg-blue-500 rounded-full" style="width:${pct}%"></div>
                        </div>
                    </div>
                `;
        }

        (async () => {
            const loading = document.getElementById("loading");
            const content = document.getElementById("content");
            const errorBox = document.getElementById("errorBox");

            try {
                const [animeRes, threadsRes, usersRes, forumsRes] = await Promise.all([
                    fetch("/api/anime"),
                    fetch("/api/threads"),
                    fetch("/api/users"),
                    fetch("/api/forums")
                ]);

                const animeData = await animeRes.json();
                const threadsData = await threadsRes.json();
                const usersData = await usersRes.json();
                const forumsData = await forumsRes.json();

                const anime = normalize(animeData);
                const threads = normalize(threadsData);
                const users = normalize(usersData);
                const forums = normalize(forumsData);

                document.getElementById("generatedAt").textContent = new Date().toLocaleString();

                // =========================
                // Top stats
                // =========================
                document.getElementById("totalUsers").textContent = users.length;
                document.getElementById("totalAnime").textContent = anime.length;
                document.getElementById("totalForums").textContent = forums.length;
                document.getElementById("totalThreads").textContent = threads.length;

                let totalPosts = 0;
                threads.forEach(t => {
                    totalPosts += Number(t.post_count || 0);
                });

                document.getElementById("totalPosts").textContent = totalPosts;

                // No real likes field in /api/threads right now
                document.getElementById("totalLikes").textContent = "0";

                // =========================
                // Top Threads by Engagement
                // =========================
                const topThreads = [...threads]
                    .sort((a, b) => {
                        const scoreA = Number(a.views || 0) + Number(a.post_count || 0) * 5;
                        const scoreB = Number(b.views || 0) + Number(b.post_count || 0) * 5;
                        return scoreB - scoreA;
                    })
                    .slice(0, 10);

                document.getElementById("engagementBody").innerHTML =
                    topThreads.length > 0
                        ? topThreads.map(t => `
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 font-medium text-gray-800">${esc(t.title)}</td>
                                    <td class="px-6 py-4">${esc(t.forum_name)}</td>
                                    <td class="px-6 py-4">${esc(t.anime_title)}</td>
                                    <td class="px-6 py-4">${Number(t.views || 0)}</td>
                                    <td class="px-6 py-4">${Number(t.post_count || 0)}</td>
                                    <td class="px-6 py-4">0</td>
                                </tr>
                            `).join("")
                        : `
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">
                                        No thread engagement data found.
                                    </td>
                                </tr>
                            `;

                // =========================
                // Most Active Forums
                // =========================
                const forumMap = {};

                threads.forEach(t => {
                    const forumName = t.forum_name || "Unknown";

                    if (!forumMap[forumName]) {
                        forumMap[forumName] = {
                            name: forumName,
                            threads: 0,
                            posts: 0
                        };
                    }

                    forumMap[forumName].threads += 1;
                    forumMap[forumName].posts += Number(t.post_count || 0);
                });

                const activeForums = Object.values(forumMap).sort((a, b) => {
                    const scoreA = a.threads + a.posts;
                    const scoreB = b.threads + b.posts;
                    return scoreB - scoreA;
                });

                document.getElementById("activeForumsBody").innerHTML =
                    activeForums.length > 0
                        ? activeForums.map(f => `
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 font-medium text-gray-800">${esc(f.name)}</td>
                                    <td class="px-6 py-4">${f.threads}</td>
                                    <td class="px-6 py-4">${f.posts}</td>
                                </tr>
                            `).join("")
                        : `
                                <tr>
                                    <td colspan="3" class="px-6 py-8 text-center text-gray-500">
                                        No forum activity data found.
                                    </td>
                                </tr>
                            `;

                // =========================
                // Anime Status Distribution
                // =========================
                const statusMap = {};

                anime.forEach(a => {
                    const status = a.status || "Unknown";
                    statusMap[status] = (statusMap[status] || 0) + 1;
                });

                const statusEntries = Object.entries(statusMap).map(([label, value]) => ({
                    label,
                    value
                }));

                const totalStatus = statusEntries.reduce((sum, item) => sum + item.value, 0);

                document.getElementById("animeStatusDistribution").innerHTML =
                    statusEntries.length > 0
                        ? statusEntries.map(item => barRow(item.label, item.value, totalStatus)).join("")
                        : `<div class="text-sm text-gray-500">No anime status data found.</div>`;

                // =========================
                // Threads Report
                // =========================
                document.getElementById("threadsReportBody").innerHTML =
                    threads.length > 0
                        ? threads.map(t => `
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 font-medium text-gray-800">${esc(t.title)}</td>
                                    <td class="px-6 py-4">${esc(t.author_username)}</td>
                                    <td class="px-6 py-4">${esc(t.anime_title)}</td>
                                    <td class="px-6 py-4">${esc(t.forum_name)}</td>
                                    <td class="px-6 py-4">${Number(t.views || 0)}</td>
                                    <td class="px-6 py-4">${Number(t.post_count || 0)}</td>
                                    <td class="px-6 py-4">${t.is_pinned ? "Pinned" : "-"}</td>
                                </tr>
                            `).join("")
                        : `
                                <tr>
                                    <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                                        No threads found.
                                    </td>
                                </tr>
                            `;

                // =========================
                // Anime API Report
                // =========================
                document.getElementById("animeApiGrid").innerHTML =
                    anime.length > 0
                        ? anime.map(a => `
                                <div class="bg-white rounded-xl shadow p-3 border border-gray-100">
                                    <img
                                        src="${esc(a.poster_url || a.large_image_url || a.image_url || "")}"
                                        alt="${esc(a.title)}"
                                        class="rounded-lg mb-3 w-full h-56 object-cover bg-gray-100"
                                    >
                                    <div class="font-semibold text-sm text-gray-800">${esc(a.title)}</div>
                                    <div class="mt-2">${badge(a.status)}</div>
                                </div>
                            `).join("")
                        : `
                                <div class="col-span-full text-center text-gray-500 py-10">
                                    No anime data found.
                                </div>
                            `;

                loading.classList.add("hidden");
                content.classList.remove("hidden");

            } catch (err) {
                console.error(err);
                loading.classList.add("hidden");
                errorBox.textContent = err.message || "Failed to load dashboard";
                errorBox.classList.remove("hidden");
            }
        })();
    </script>
</body>

</html>