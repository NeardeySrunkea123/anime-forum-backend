<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add User - Anime Forum Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <div class="flex h-screen">

        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow flex flex-col">
            <div class="p-6 text-center border-b">
                <h1 class="text-xl font-bold text-blue-600">Anime Forum Admin</h1>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">
                <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Dashboard</a>
                <a href="/users" class="block px-4 py-2 rounded-lg bg-blue-50 text-blue-700 font-semibold">Users</a>
                <a href="/dashboard/anime" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Anime</a>
            </nav>

            <div class="p-4 text-xs text-gray-500 border-t text-center">
                © 2026 Anime Forum
            </div>
        </aside>

        <!-- Main -->
        <main class="flex-1 p-8 overflow-y-auto">
            <div class="max-w-2xl mx-auto">

                <!-- Header -->
                <div class="mb-6">
                    <a href="/users" class="text-sm text-gray-600 hover:text-gray-900">← Back to users</a>
                    <h2 class="text-2xl font-bold text-gray-800 mt-2">➕ Add User</h2>
                </div>

                <!-- Error / Success -->
                <% if (error) { %>
                    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        <%= error %>
                    </div>
                    <% } %>

                        <% if (success) { %>
                            <div
                                class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                                <%= success %>
                            </div>
                            <% } %>

                                <!-- Form -->
                                <div class="bg-white rounded-xl shadow p-6">
                                    <form action="/admin/users/create" method="POST" class="space-y-4">

                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                                                <input name="username" required
                                                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                                                    placeholder="e.g. naruto_fan" />
                                            </div>

                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                                                <input type="email" name="email" required
                                                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                                                    placeholder="e.g. user@example.com" />
                                            </div>
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Password
                                                (temporary)</label>
                                            <input type="password" name="password" required minlength="4"
                                                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                                                placeholder="Set a password (we will hash it)" />
                                            <p class="text-xs text-gray-400 mt-1">
                                                Later you can replace this with Google login / NextAuth.
                                            </p>
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Avatar URL
                                                (optional)</label>
                                            <input name="avatar_url"
                                                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                                                placeholder="https://i.pravatar.cc/150?img=10" />
                                        </div>

                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Bio
                                                (optional)</label>
                                            <textarea name="bio" rows="3"
                                                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                                                placeholder="Short user bio..."></textarea>
                                        </div>

                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                                                <select name="role"
                                                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 outline-none">
                                                    <option value="user">user</option>
                                                    <option value="moderator">moderator</option>
                                                    <option value="admin">admin</option>
                                                </select>
                                            </div>

                                            <div class="flex items-center gap-2 mt-6 md:mt-0">
                                                <input id="is_active" type="checkbox" name="is_active" checked
                                                    class="h-4 w-4" />
                                                <label for="is_active" class="text-sm text-gray-700">Active</label>
                                            </div>
                                        </div>

                                        <div class="pt-3 flex items-center justify-between">
                                            <a href="/users"
                                                class="text-sm text-gray-600 hover:text-gray-900">Cancel</a>
                                            <button type="submit"
                                                class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 font-medium">
                                                Save User
                                            </button>
                                        </div>

                                    </form>
                                </div>

            </div>
        </main>
    </div>
</body>

</html>