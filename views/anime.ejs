<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anime - Anime Forum Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <div class="flex h-screen">

        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow flex flex-col">
            <div class="p-6 text-center border-b">
                <h1 class="text-xl font-bold text-blue-600">Anime Forum Admin</h1>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">
                <a href="/dashboard" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Dashboard</a>
                <a href="/users" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Users</a>
                <a href="/dashboard/anime" class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-gray-100">Anime</a>
            </nav>


            <div class="p-4 text-xs text-gray-500 border-t text-center">
                © 2026 Anime Forum
            </div>
        </aside>

        <!-- Main -->
        <main class="flex-1 p-8 overflow-y-auto">

            <!-- Header -->
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800">Anime Listing</h2>
                    <p class="text-sm text-gray-500">Manage anime records used across the forum.</p>
                </div>
            </div>

            <!-- Search + Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <!-- Total -->
                <div class="bg-white rounded-xl shadow p-4">
                    <div class="text-sm text-gray-500">Total Anime</div>
                    <div class="text-2xl font-bold text-gray-800 mt-1">
                        <%= (anime && anime.length) ? anime.length : 0 %>
                    </div>
                    <div class="text-xs text-gray-400 mt-1">From your PostgreSQL database</div>
                </div>

                <!-- Search -->
                <div class="bg-white rounded-xl shadow p-4 md:col-span-2">
                    <div class="text-sm text-gray-500 mb-2">Search (UI only)</div>
                    <div class="flex items-center gap-2 border rounded-lg px-3 py-2 bg-gray-50">
                        <span class="text-gray-400">🔍</span>
                        <input class="w-full bg-transparent outline-none text-sm"
                            placeholder="Search by title (wire later to ?q=...)"  />
                        <button class="text-sm px-3 py-1.5 rounded-lg bg-white border hover:bg-gray-50 text-gray-700"
                            >
                            Search
                        </button>
                    </div>
                    <p class="text-xs text-gray-400 mt-2">
                        Tip: later connect it to route like <code
                            class="bg-gray-100 px-1 rounded">/dashboard/anime?q=naruto</code>
                    </p>
                </div>
            </div>

            <!-- Table -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <div class="px-6 py-4 border-b flex items-center justify-between">
                    <h3 class="font-semibold text-gray-800">Anime Records</h3>
                    <span class="text-sm text-gray-500">
                        Showing <b>
                            <%= (anime && anime.length) ? anime.length : 0 %>
                        </b>
                    </span>
                </div>

                <table class="w-full text-sm text-left">
                    <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                        <tr>
                            <th class="px-6 py-3">Poster</th>
                            <th class="px-6 py-3">Title</th>
                            <th class="px-6 py-3">Status</th>
                            <th class="px-6 py-3">UUID</th>
                            <th class="px-6 py-3">Actions</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y">
                        <% if (!anime || anime.length===0) { %>
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                                    No anime found. Click <b>Add Anime</b> to create your first record.
                                </td>
                            </tr>
                            <% } %>

                                <% anime.forEach(a=> { %>
                                    <tr class="hover:bg-gray-50">
                                        <!-- Poster -->
                                        <td class="px-6 py-4">
                                            <div class="w-12 h-16 rounded-lg overflow-hidden bg-gray-100 border">
                                                <% if (a.poster_url) { %>
                                                    <img src="<%= a.poster_url %>" alt="<%= a.title %>"
                                                        class="w-full h-full object-cover" />
                                                    <% } else { %>
                                                        <div
                                                            class="w-full h-full flex items-center justify-center text-gray-400 text-xs">
                                                            No Image
                                                        </div>
                                                        <% } %>
                                            </div>
                                        </td>

                                        <!-- Title -->
                                        <td class="px-6 py-4">
                                            <div class="font-semibold text-gray-800">
                                                <%= a.title %>
                                            </div>
                                            <div class="text-xs text-gray-500 mt-1">Used for threads linkage</div>
                                        </td>

                                        <!-- Status -->
                                        <td class="px-6 py-4">
                                            <% const s=(a.status || '' ).toLowerCase(); const statusClass=s==='ongoing'
                                                ? 'bg-green-50 text-green-700 border-green-200' : s==='completed'
                                                ? 'bg-blue-50 text-blue-700 border-blue-200' : s==='upcoming'
                                                ? 'bg-purple-50 text-purple-700 border-purple-200'
                                                : 'bg-gray-100 text-gray-700 border-gray-200' ; %>
                                                <span class="px-2 py-1 rounded border text-xs <%= statusClass %>">
                                                    <%= a.status || 'unknown' %>
                                                </span>
                                        </td>

                                        <!-- UUID -->
                                        <td class="px-6 py-4">
                                            <code class="text-xs bg-gray-100 px-2 py-1 rounded">
                    <%= a.uuid %>
                  </code>
                                        </td>

                                        <!-- Actions -->
                                        <td class="px-6 py-4 space-x-2">
                                            <a href="/admin/anime/edit/<%= a.uuid %>"
                                                class="text-blue-600 hover:underline">
                                                ✏️ Edit
                                            </a>
                                            <a href="/admin/anime/delete/<%= a.uuid %>"
                                                onclick="return confirm('Delete this anime?')"
                                                class="text-red-600 hover:underline">
                                                🗑 Delete
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Footer note -->
            <div class="text-xs text-gray-500 mt-4">
                Note: your threads table uses <code class="bg-gray-100 px-1 rounded">anime_uuid</code> foreign key to
                connect discussions to anime.
            </div>

        </main>
    </div>
</body>

</html>